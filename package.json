{
  "name": "memento-mori-obituary-comics",
  "private": true,
  "description": "Next.js obituary-comics archive on Cloudflare Workers with private R2 media and an x402-paid latest-PDF endpoint.",
  "homepage": "https://www.finalnotes.page/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/megabyte0x/memento-mori-obituary-comics.git"
  },
  "bugs": {
    "url": "https://github.com/megabyte0x/memento-mori-obituary-comics/issues"
  },
  "keywords": [
    "nextjs",
    "digital-archive",
    "comics",
    "cloudflare-workers",
    "cloudflare-r2",
    "x402",
    "agentic-web"
  ],
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:images": "CLOUDFLARE_IMAGE_TRANSFORMATIONS=1 opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "r2:upload-live": "node scripts/upload_comics_to_live_blob.js",
    "r2:upload-live:dry-run": "node scripts/upload_comics_to_live_blob.js --dry-run",
    "r2:verify-live": "node scripts/verify_live_blob_upload.js",
    "comic:seed-catalog": "node scripts/seed_r2_comic_catalog.js",
    "comic:publish": "node scripts/publish_comic_to_r2.js",
    "test": "python3 -m unittest discover -s tests -p 'test_*.py' && node --test tests/*.test.js"
  },
  "dependencies": {
    "@coinbase/x402": "2.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@x402/core": "2.13.0",
    "@x402/evm": "2.13.0",
    "@x402/hono": "2.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "4.12.21",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "wrangler": "^4.110.0"
  }
}
